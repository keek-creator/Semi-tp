-- === FUNCTIONS ===
local function GetTargetPlot()
    local myPlot = nil
    for _, plot in pairs(workspace:WaitForChild('Plots'):GetChildren()) do
        if plot:FindFirstChild('AnimalPodiums') then
            myPlot = plot
            break
        end
    end
    return myPlot
end

local function FindNearestBrainrot()
    local hrpPos = HRP.Position
    local nearest = nil
    local nearestDist = math.huge

    for _, plot in pairs(workspace:WaitForChild('Plots'):GetChildren()) do
        local podiums = plot:FindFirstChild('AnimalPodiums')
        if podiums then
            for _, pod in pairs(podiums:GetChildren()) do
                local prompt = pod:FindFirstChild('Base') and pod.Base:FindFirstChild('Spawn')
                    and pod.Base.Spawn:FindFirstChild('PromptAttachment')
                    and pod.Base.Spawn.PromptAttachment:FindFirstChild('ProximityPrompt')
                if prompt then
                    local dist = (pod.Base.Spawn.PromptAttachment.WorldPosition - hrpPos).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = pod.Base.Spawn.PromptAttachment
                    end
                end
            end
        end
    end
    return nearest
end

local function DoManualBlock()
    local target = FindNearestBrainrot()
    if target then
        ShowToast('Blocking: ' .. (target.Parent.Parent.Parent.Parent.Name or 'target'))
        if S.TeleportMode == 1 then
            HRP.CFrame = CFrame.new(target.WorldPosition)
            HRP.AssemblyLinearVelocity = Vector3.new(0, 160, 0)
            task.wait(0.1)
            HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        else
            HRP.CFrame = CFrame.new(target.WorldPosition)
        end
    else
        ShowToast('No players found to block')
    end
end

local function DoTeleport()
    local target = FindNearestBrainrot()
    if target then
        ShowToast('Teleporting...')
        if S.TeleportMode == 1 then
            HRP.CFrame = CFrame.new(target.WorldPosition)
            HRP.AssemblyLinearVelocity = Vector3.new(0, 160, 0)
            task.wait(0.1)
            HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        else
            HRP.CFrame = CFrame.new(target.WorldPosition)
        end
    else
        ShowToast('No targets found')
    end
end

-- Auto Steal loop
local AutoStealConnection
local function UpdateAutoSteal()
    if AutoStealConnection then AutoStealConnection:Disconnect() end
    if not S.AutoSteal then return end
    AutoStealConnection = RunService.Heartbeat:Connect(function()
        task.spawn(function()
            local target = FindNearestBrainrot()
            if target then
                if S.TeleportMode == 1 then
                    HRP.CFrame = CFrame.new(target.WorldPosition)
                    HRP.AssemblyLinearVelocity = Vector3.new(0, 160, 0)
                    task.wait(0.05)
                    HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                else
                    HRP.CFrame = CFrame.new(target.WorldPosition)
                end
            end
        end)
        task.wait(1)
    end)
end

-- Auto Block loop
local AutoBlockConnection
local function UpdateAutoBlock()
    if AutoBlockConnection then AutoBlockConnection:Disconnect() end
    if not S.AutoBlock then return end
    AutoBlockConnection = RunService.Heartbeat:Connect(function()
        task.spawn(DoManualBlock)
        task.wait(0.5)
    end)
end

